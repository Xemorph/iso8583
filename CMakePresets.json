{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "ISO8583_BUILD_SHARED": "ON",
        "ISO8583_ENABLE_ICONV": "ON",
        "ISO8583_INSTALL":      "OFF"
      }
    },

    {
      "name": "debug",
      "displayName": "Debug (Ninja)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE":   "Debug",
        "ISO8583_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release (Ninja)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE":    "Release",
        "ISO8583_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "debug-bertlv",
      "displayName": "Debug (Ninja) - BER-TLV/int32_t-Keys",
      "inherits": "debug",
      "cacheVariables": {
        "ISO8583_BERTLV": "ON"
      }
    },

    {
      "name": "msvc-debug",
      "displayName": "Debug (MSVC)",
      "inherits": "base",
      "generator": "Visual Studio 17 2022",
      "architecture": { "value": "x64", "strategy": "set" },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE":    "Debug",
        "ISO8583_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "msvc-release",
      "displayName": "Release (MSVC)",
      "inherits": "msvc-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE":    "Release",
        "ISO8583_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "msvc-debug-static",
      "displayName": "Debug (MSVC) - fmt/yaml-cpp/... statisch in iso8583.dll",
      "inherits": "msvc-debug",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static-md"
      }
    },
    {
      "name": "msvc-release-static",
      "displayName": "Release (MSVC) - fmt/yaml-cpp/... statisch in iso8583.dll",
      "inherits": "msvc-release",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static-md"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "debug-bertlv",
      "configurePreset": "debug-bertlv"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "msvc-debug",
      "configurePreset": "msvc-debug",
      "configuration": "Debug"
    },
    {
      "name": "msvc-release",
      "configurePreset": "msvc-release",
      "configuration": "Release"
    },
    {
      "name": "msvc-debug-static",
      "configurePreset": "msvc-debug-static",
      "configuration": "Debug"
    },
    {
      "name": "msvc-release-static",
      "configurePreset": "msvc-release-static",
      "configuration": "Release"
    }
  ],

  "testPresets": [
    {
      "name": "debug",
      "displayName": "Alle Tests (Debug)",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true,
        "verbosity": "default"
      },
      "filter": {
        "exclude": { "label": "slow" }
      }
    },
    {
      "name": "debug-bertlv",
      "displayName": "Alle Tests (Debug, int32_t-Keys)",
      "configurePreset": "debug-bertlv",
      "output": {
        "outputOnFailure": true,
        "verbosity": "default"
      },
      "filter": {
        "exclude": { "label": "slow" }
      }
    },
    {
      "name": "msvc-debug",
      "displayName": "Alle Tests (MSVC Debug)",
      "configurePreset": "msvc-debug",
      "configuration": "Debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "msvc-debug-static",
      "displayName": "Alle Tests (MSVC Debug, statische vcpkg-Libs)",
      "configurePreset": "msvc-debug-static",
      "configuration": "Debug",
      "output": { "outputOnFailure": true }
    }
  ]
}
